<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/profile_gradient_background"
    android:fitsSystemWindows="true"
    tools:context=".HelpActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            android:title="Help Support"
            android:titleTextColor="#FFFFFF"
            app:titleTextAppearance="@style/TextAppearance.Widget.AppCompat.Toolbar.Title" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Contact Support Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1E293B"
                app:strokeColor="#38BDF8"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Support"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"
                        android:drawablePadding="8dp" />

                    <!-- Contact Options -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get in Touch"
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnContactSupport"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp"
                                android:text="Contact Support"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                app:backgroundTint="#38BDF8"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/ic_dialog_email"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFAQ"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp"
                                android:text="Frequently Asked Questions"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                app:backgroundTint="#38BDF8"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/ic_menu_help"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUserGuide"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp"
                                android:text="User Guide"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                app:backgroundTint="#38BDF8"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/ic_menu_help"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnVideoTutorials"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="Video Tutorials"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                app:backgroundTint="#38BDF8"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/ic_menu_slideshow"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Help Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1E293B"
                app:strokeColor="#38BDF8"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Help"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"
                        android:drawablePadding="8dp" />

                    <!-- Quick Help Options -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Need Immediate Assistance?"
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnEmergencyContact"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp"
                                android:text="Emergency Contact"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                app:backgroundTint="#38BDF8"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/stat_sys_warning"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnLiveChat"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp"
                                android:text="Live Chat Support"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                app:backgroundTint="#38BDF8"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/ic_menu_send"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnReportIssue"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="Report an Issue"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                app:backgroundTint="#38BDF8"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/ic_dialog_alert"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Progress Indicator -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="#38BDF8"
        app:indicatorSize="48dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>